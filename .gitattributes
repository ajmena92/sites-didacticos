# Auto detect text files by default
* text=auto

# Keep source/content files in LF across platforms
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.svg text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Repo config files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary assets
*.xlsx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
